# NullTrace — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/nulltrace

# Groq API key — get one free at https://console.groq.com
# Powers the AI chat (Llama 3.3-70B) and RCA engine
GROQ_API_KEY=gsk_your_groq_api_key_here

# Random secret for session signing (run: openssl rand -base64 32)
SESSION_SECRET=your_session_secret_here

# ── Server config ─────────────────────────────────────────────────────────────

# Port the API server listens on
PORT=8080

# Base path for the frontend (set to / for root deployment)
BASE_PATH=/

NODE_ENV=development
